rules_version = '2';

// Paste this into Firebase Console → Firestore Database → Rules, then Publish.
// Public visitors can read hymns & site settings (needed for the website to
// display them); only signed-in admin accounts can create/edit/delete them.
service cloud.firestore {
  match /databases/{database}/documents {

    match /hymns/{hymnId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny everything else by default until it's explicitly needed.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
