rules_version = '2';

// Paste this into Firebase Console → Firestore Database → Rules, then Publish.
service cloud.firestore {
  match /databases/{database}/documents {

    // Hymns — public read, admin write
    match /hymns/{hymnId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Site settings — public read, admin write
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Church leadership — public read, admin write
    match /leaders/{leaderId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Choir & Media Team registrations
    // Public can create (sign-up form), only admins can read/update/delete
    match /choir_members/{memberId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // Admin user profiles — only signed-in admins can read/write
    match /admin_users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
